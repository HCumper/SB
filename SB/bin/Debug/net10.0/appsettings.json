{
  "ApplicationName": "SB",
  "AppSettings": {
    "InputFile": "C:\\Source\\SB\\SB\\project planner.sb",
    "OutputFile": "C:\\Source\\SB\\output\\golfer.exe",
    "Verbose": false,
    "Backend": "dotnetexe",
    "RuntimeHost": "avalonia",
    "SyntaxChecking": "relaxed",
    "ExecutionThrottle": {
      "Enabled": false,
      "TargetStatementsPerSecond": 100,
      "MaxRunAheadMilliseconds": 5
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "System": "Warning",
        "Microsoft": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/SB.log",
          "rollingInterval": "Day"
        }
      }
    ]
  }
}
