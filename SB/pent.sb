4095 IF char=130 THEN time (1)
4100 CSIZE 2,1 : STRIP 2 : INK 5
4105 key1=KEYROW(1)
4110 BEP 300,100
4115 IF key1<>0 AND key1<>key2 AND power<limit THEN n=n+1
4117 IF power<limit AND n=INT(level) THEN power=power+1
4120 IF n=INT(level) THEN n=0 : pow_to=pow_to+power
4122 IF power>=limit AND power>8 THEN power=power-1
4125 IF power>8 AND (key1=0 OR key1=key2) AND power<limit THEN power=power-.1666667
4130 AT #3,1,power : STRIP #3,0 : PRINT #3," " : STRIP #3,7,0 : AT #3,1,power+1 : PRINT #3," "
4135 key2=key1 : IF total>25 THEN total=total-(power*.95)
4140 IF char=130 THEN char=131 : ELSE char=130
4143 IF pow_to>240 AND limit>10 THEN limit=INT(limit-(total/40)) : pow_to=0
4145 IF co>=30 THEN co=0 : INK #6,7 : POINT #6,732,100 : POINT #6,732,0
4146 CSIZE 2,1 : STRIP 2 : INK 5
4150 IF NOT gm THEN AT 8,14 : PRINT " " : PAN #6,-power : AT 8,14 : PRINT CHR$(char)
4155 IF gm THEN AT 8,14 : PRINT " " : PAN #6,-25 : AT 8,14 : PRINT CHR$(char)
4160 co=co+power
4165 IF total<100 AND tot THEN LINE #6,730,100 TO 680,0 : tot=0
4170 IF total<100 THEN fin=fin-power
4175 IF fin<=0 THEN EXIT lo_sprint_1
