5300 DEFine PROCedure leap
5310 angle=10 : STRIP #3,7 : INK #3,2
5315 AT #3,1,36 : PRINT #3,angle
5320 REPeat angle_jump
5325 IF KEYROW(1)=0 OR angle>80 THEN EXIT angle_jump
5330 angle=angle+3
5335 AT #3,1,36 : PRINT #3,angle
5340 END REPeat angle_jump
5345 BEP 300,5
5346 IF angle>=50 THEN decr=(4.2/angle)*10 : ELSE decr=(angle/55)
5350 dist=(power*4)*decr
5352 distance=-((30-y)*.5)
5355 INK 1
5356 ne=4
5360 AT x,y : PRINT " " : PAN #8,-10 : STRIP ne : AT x-1,y : PRINT CHR$(134)
5365 x=x-1
5366 FOR i=1 TO 150 : END FOR i
5370 AT x,y : PRINT " " : PAN #8,-10 : STRIP ne : AT x-1,y : PRINT CHR$(134)
5375 x=x-1
5376 INK #8,2
5380 FOR i=1 TO (dist/5)
5385 FOR j=1 TO 60 : END FOR j
5390 PAN #8,-10
5395 distance=distance+.5
5400 END FOR i
5410 IF distance>=1 THEN ne=6 : ELSE ne=2
5420 AT x,y : PRINT " " : PAN #8,-15 : CSIZE 2,0 : AT (x*2)+1,y : CSIZE 2,1 : PRINT CHR$(134)
5430 FOR i=1 TO 150 : END FOR i
5435 CSIZE 2,0 : AT (x*2)+1,y : CSIZE 2,1 : PRINT " " : STRIP ne : PAN #8,-20 : AT x+2,y : PRINT CHR$(134)
5436 dist1=distance
5438 IF distance<=0 THEN distance=0
5440 IF distance>0 THEN distance=distance+(INT(RND(1 TO 49))/100)
5445 CSIZE 2,0 : STRIP 4 : INK 2
5446 AT 11,1 : PRINT "YOUR JUMP WAS ";distance;"m"
5450 IF distance<10 THEN AT #4,pos,14 : PRINT #4,"0";distance : ELSE AT #4,pos,14 : PRINT #4,distance
5455 BEP 1000,1
5460 IF NOT qual AND distance>7.26 THEN qual=1 : INK 0 : STRIP 4 : AT 13,1 : PRINT "YOU HAVE QUALIFIED"
5465 score=score+INT((distance*10)*4)
5470 INK #4,2
5475 IF score>9 AND score<100 THEN AT #4,0,10 : PRINT #4,2
5480 IF score>99 AND score<1000 THEN AT #4,0,9 : PRINT #4,score
5485 IF score>999 AND score<10000 THEN AT #4,0,8 : PRINT #4,score
5486 IF score>9999 THEN AT #4,0,7 : PRINT #4,score
5490 END DEFine 
