3195 INK #4,7 : AT #4,pos,14 : PRINT #4,"-----"
3200 pos=pos+1
3205 INK #4,2
3210 IF score>9 AND score<100 THEN AT #4,0,10 : PRINT #4,score
3215 IF score>99 AND score<1000 THEN AT #4,0,9 : PRINT #4,score
3220 IF score>999 AND score<10000 THEN AT #4,0,8 : PRINT #4,score
