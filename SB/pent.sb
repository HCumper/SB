5086 IF key1>=64 AND key1<100 THEN EXIT jump_1
5090 AT #3,1,power : STRIP #3,0 : PRINT #3," " : STRIP #3,7,0 : AT #3,1,power+1 : PRINT #3," "
5095 key2=key1
