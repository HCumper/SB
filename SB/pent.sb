22000 DEFine PROCedure print_hi_scores
22005 INK #4,6
22010 IF wr<10 THEN AT #4,6,38 : PRINT #4,wr
22020 IF wr>9 THEN AT #4,6,37 : PRINT #4,wr
22030 INK #4,7
22040 FOR i=1 TO 3
22045 IF hi(event,i)<10 THEN 
22050 AT #4,i+1,27 : PRINT #4,"0";hi(event,i)
22055 ELSE 
22057 AT #4,i+1,27 : PRINT #4,hi(event,i)
22058 END IF 
22060 AT #4,i+1,37 : PRINT #4,hi$(event,i)
22070 END FOR i
22080 END DEFine 
