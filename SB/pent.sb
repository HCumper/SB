19000 DEFine PROCedure hi_scores_2
19010 LOCal i
19015 hi(event,0)=tme
19020 hi$(event,0)=a$
19025 IF hi(event,0)<hi(event,1) THEN 
19030 wr=wr+1
19035 FOR i=3 TO 1 STEP -1
19040 hi(event,i)=hi(event,i-1)
19045 hi$(event,i)=hi$(event,i-1)
19050 END FOR i
19055 RETurn 
19060 END IF 
19065 IF hi(event,0)<hi(event,2) THEN 
19070 hi(event,3)=hi(event,2) : hi$(event,3)=hi$(event,2)
19075 hi(event,2)=hi(event,0) : hi$(event,2)=hi$(event,0)
19080 wr=wr+1
19085 RETurn 
19090 END IF 
19095 IF hi(event,0)<hi(event,3) THEN 
19096 wr=wr+1
19097 hi(event,3)=hi(event,0) : hi$(event,3)=hi$(event,0)
19098 RETurn 
19099 END IF 
19100 END DEFine 
