2110 CSIZE 2,1 : STRIP 2 : INK 5
2120 key1=KEYROW(1)
2125 BEP 300,100
2130 IF key1<>0 AND key1<>key2 AND power<23.5 THEN n=n+1
2135 IF n=level2 THEN power=power+1 : n=0
2140 IF power>8 AND (key1=0 OR key1=key2) THEN power=power-lim
2145 AT #3,1,power : STRIP #3,0 : PRINT #3," " : STRIP #3,7,0 : AT #3,1,power+1 : PRINT #3," "
2150 key2=key1
2155 total=total-power
2160 IF char=130 THEN char=131 : ELSE char=130
2162 IF co>=30 THEN co=0 : INK #6,7 : POINT #6,732,0 : POINT #6,732,100
2165 IF NOT gm THEN AT 8,14 : PRINT " " : PAN #6,-power : AT 8,14 : PRINT CHR$(char)
2170 IF gm THEN AT 8,14 : PRINT " " : PAN #6,-25 : AT 8,14 : PRINT CHR$(char)
2175 co=co+power
2180 IF total<100 AND tot THEN LINE #6,730,100 TO 680,0 : tot=0
2182 IF total<100 THEN fin=fin-power
2183 IF fin<=0 THEN EXIT sprint_1
2185 gm=0
2190 END REPeat sprint_1
2195 tme=ut$(19 TO )+(INT(RND(1 TO 98))/100)
2200 CSIZE 2,0 : STRIP 2 : INK 5
2205 IF tme<10 THEN AT 8,35 : PRINT "0";tme : ELSE AT 8,35 : PRINT tme
2210 BEP 1000,1
2215 IF tme<10 THEN AT #4,pos,14 : PRINT #4,"0";tme : ELSE AT #4,pos,14 : PRINT #4,tme
2220 pos=pos+1
2225 IF NOT qual AND tme<12.65 THEN qual=1 : INK 0 : STRIP 4 : AT 13,1 : PRINT "YOU HAVE QUALIFIED"
2230 score=score+INT((30-tme)*15)
2232 INK #4,2
2235 IF score>9 AND score<100 THEN AT #4,0,10 : PRINT #4,score
2240 IF score>99 AND score<1000 THEN AT #4,0,9 : PRINT #4,score
2245 IF score>999 AND score<10000 THEN AT #4,0,8 : PRINT #4,score
2246 IF score>9999 THEN AT #4,0,7 : PRINT #4,score
2250 hi_scores_2
2255 print_hi_scores
2260 FOR i=1 TO 1500 : END FOR i
2265 AT 13,1 : STRIP 4 : PRINT "                   "
2270 IF pos=5 THEN EXIT sprint_loop
2275 END REPeat sprint_loop
2280 qualify=qual
2285 END DEFine 
2999 :
