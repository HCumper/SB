3870 REMark =========================================================
3880 REMark Project initialization
3890 REMark =========================================================
3900 DEFine PROCedure createNewProjectDisplay
3910   showMessage "initializing; max activities " & (maxActivities + 1)
3920   initializeViewState
3930   projectListActive = 1
3940   currentActivityIndex = -1
3950   successorFreeListHead = 1000
3960   freeEdgeListHead = 0
3970   :
3980   FOR i = 0 TO maxActivities
3990     activityName$(i)         = FILL$(" ",16)
4000     activityDuration$(i)     = "   "
4010     activityCost$(i)         = "      "
4020     activityPrereqText$(i)   = FILL$(" ",30)
4030     listPositionToActivity%(i) = i
4040     activityToListPosition%(i) = 100
4050     successorHead%(i)          = 1000
4060   END FOR i
4070   :
4080   edgeCount = (maxActivities + 1) * fieldWidth10 - 1
4090   FOR i = 0 TO edgeCount
4100     edgeChild%(i) = 100
4110     edgeNext%(i)  = i + 1
4120   END FOR i
4130   edgeNext%(i) = 1000
4140   :
4150   projectRemark$   = FILL$(" ",20)
4160   projectStartDate$ = "850101"
4170   projectStartDayNumber = 8766
4180   specialHolidayCount = 0
4190   numberWorkingDays = 2
4200   :
4210   FOR i = 1 TO 5
4220     workingDayEnabled%(i) = 1
4230   END FOR i
4240   workingDayEnabled%(0) = 0
4250   workingDayEnabled%(6) = 0
4260   :
4270   FOR i = 0 TO fieldWidth10
4280     milestoneActivity%(i) = 1000
4290     milestoneDate$(i) = "      "
4300   END FOR i
4310   milestoneActivity%(0) = 0
4320   :
4330   FOR i = 1 TO maxSpecialHolidays
4340     specialHolidayDate$(i) = FILL$(" ",6)
4350   END FOR i
4360 END DEFine createNewProjectDisplay
4370 :
4380 :
4390 DEFine PROCedure initializeProject
4400   createNewProjectDisplay
4410 END DEFine initializeProject
4420 :
4430 :
4440 DEFine PROCedure initializeViewState
4450   topActivity         = 0
4460   currentActivity     = 0
4470   currentLineInView   = 0
4480   displayMode         = 1
4490   scheduleCalculated  = 0
4500   dateCalculated      = 0
4510   milestoneListMode   = 0
4520   totalProjectLength  = 0
4530   chartScale          = 0
4540   chartLeftOffset     = 0
4550   chartModeEnabled    = 0
4560 END DEFine initializeViewState
4570 :
4580 :
4590 REMark =========================================================
4600 REMark File menu
4610 REMark =========================================================
4620 DEFine PROCedure fileMenu
4630   LOCal x,y
4640   :
4650   projectListActive = 0
4660   x = 0
4670   y = 0
4680   drawMenu 2,0,0
4690   :
4700   REPeat fileLoop
4710     CLS #8
4720     PAPER #fieldWidth9,7
4730     CLS #fieldWidth9
4740     :
4750     handleMenuHighlight x,y,5,lastKey,0
4760     :
4770     SELect ON x
4780       =0
4790         showDirectory
4800       =9
4810         saveProject
4820       =18
4830         loadProject
4840       =27
4850         eraseProject
4860     END SELect
4870     :
4880     IF x = 36 THEN EXIT fileLoop
4890   END REPeat fileLoop
4900 END DEFine fileMenu
4910 :
4920 :
4930 DEFine FuNction askDevice$
4940   CLS #8
4950   showMessage " Which device "
4960   AT #8,0,1
4970   PRINT #8,"?"!dataDevice$
4980   :
4990   escapeMode = 1
5000   editField 3,6,1,4,dataDevice$,32,128,8,0,1
5010   escapeMode = 0
5020   :
5030   RETurn dataDevice$
5040 END DEFine askDevice$
5050 :
5060 :
5070 DEFine FuNction askProjectName$
5080   CLS #8
5090   showMessage " Input name;max 10 chars "
5100   tempName$ = "          "
5110   AT #8,0,1
5120   PRINT #8,"?"!tempName$
5130   :
5140   escapeMode = 1
5150   editField 3,12,1,10,tempName$,32,128,8,0,1
5160   escapeMode = 0
5170   :
5180   RETurn tempName$
5190 END DEFine askProjectName$
5200 :
5210 :
5220 DEFine PROCedure saveProject
5230   saveDevice$ = askDevice$
5240   IF lastKey = 27 THEN RETurn
5250   :
5260   saveName$ = askProjectName$
5270   IF lastKey = 27 THEN RETurn
5280   :
5290   trimTrailingSpaces saveName$
5300   :
5310   status = FOP_NEW(#15, saveDevice$ & "_data_" & saveName$)
5320   IF status <> 0 THEN
5330     showError 11,""
5340     RETurn
5350   END IF
5360   :
5370   PRINT #15,maxActivities\successorFreeListHead\freeEdgeListHead\currentActivityIndex\specialHolidayCount\projectName$\projectRemark$\projectStartDate$
5380   :
5390   FOR i = 0 TO maxActivities
5400     PRINT #15, activityName$(i)\activityDuration$(i)\activityPrereqText$(i)\activityCost$(i)\successorHead%(i)\listPositionToActivity%(i)\activityToListPosition%(i)
5410   END FOR i
5420   :
5430   FOR i = 0 TO (maxActivities + 1) * fieldWidth10
5440     PRINT #15, edgeChild%(i)\edgeNext%(i)
5450   END FOR i
5460   :
5470   FOR i = 0 TO 6
5480     PRINT #15, workingDayEnabled%(i)
5490   END FOR i
5500   :
5510   FOR i = 0 TO maxSpecialHolidays
5520     PRINT #15, specialHolidayDate$(i)
5530   END FOR i
5540   :
5550   FOR i = 0 TO fieldWidth10
5560     PRINT #15, milestoneActivity%(i)\milestoneDate$(i)
5570   END FOR i
5580   :
5590   CLOSE #15
5600 END DEFine saveProject
5610 :
5620 :
5630 DEFine PROCedure loadProject
5640   initializeViewState
5650   :
5660   loadDevice$ = askDevice$
5670   IF lastKey = 27 THEN RETurn
5680   :
5690   loadName$ = askProjectName$
5700   IF lastKey = 27 THEN RETurn
5710   :
5720   trimTrailingSpaces loadName$
5730   :
5740   status = FOPEN(#15, loadDevice$ & "_data_" & loadName$)
5750   IF status <> 0 THEN
5760     showError 11,loadName$
5770     RETurn
5780   END IF
5790   :
5800   INPUT #15,tempActivityLimit\successorFreeListHead\freeEdgeListHead\currentActivityIndex\specialHolidayCount\projectName$\projectRemark$\projectStartDate$
5810   :
5820   FOR i = 0 TO tempActivityLimit
5830     INPUT #15, activityName$(i)\activityDuration$(i)\activityPrereqText$(i)\activityCost$(i)\successorHead%(i)\listPositionToActivity%(i)\activityToListPosition%(i)
5840   END FOR i
5850   :
5860   FOR i = 0 TO (tempActivityLimit + 1) * fieldWidth10
5870     INPUT #15, edgeChild%(i)\edgeNext%(i)
5880   END FOR i
5890   :
5900   FOR i = 0 TO 6
5910     INPUT #15, workingDayEnabled%(i)
5920   END FOR i
5930   :
5940   FOR i = 0 TO maxSpecialHolidays
5950     INPUT #15, specialHolidayDate$(i)
5960   END FOR i
5970   :
5980   FOR i = 0 TO fieldWidth10
5990     INPUT #15, milestoneActivity%(i)\milestoneDate$(i)
6000   END FOR i
6010   :
6020   CLOSE #15
6030   :
6040   currentActivity = listPositionToActivity%(0)
6050   topActivity     = currentActivity
6060   currentLineInView = 0
6070   :
6080   setMonthOffsets dt$(projectStartDate$)
6090   projectStartDayNumber = (dt$(projectStartDate$) - 1961) * 365 + (dt$(projectStartDate$) - 1961) DIV fieldWidth4 + monthOffset%(projectStartDate$(fieldWidth3 TO fieldWidth4)) + projectStartDate$(5 TO 6) - 2
6100 END DEFine loadProject
6110 :
6120 :
6130 DEFine PROCedure showDirectory
6140   directoryDevice$ = askDevice$
6150   IF lastKey = 27 THEN RETurn
6160   :
6170   trimTrailingSpaces directoryDevice$
6180   CLS #fieldWidth3
6190   :
6200   status = FOP_DIR(#15, directoryDevice$ & "_d")
6210   IF status <> 0 THEN
6220     showError 11,directoryDevice$
6230     RETurn
6240   END IF
6250   :
6260   CLOSE #15
6270   DIR #fieldWidth3, directoryDevice$ & "_"
6280 END DEFine showDirectory
6290 :
6300 :
6310 DEFine PROCedure eraseProject
6320   eraseDevice$ = askDevice$
6330   IF lastKey = 27 THEN RETurn
6340   :
6350   eraseName$ = askProjectName$
6360   IF lastKey = 27 THEN RETurn
6370   :
6380   trimTrailingSpaces eraseName$
6390   status = FOPEN(#15, eraseDevice$ & "_data_" & eraseName$)
6400   IF status <> 0 THEN
6410     showError 11,eraseName$
6420     RETurn
6430   ELSE
6440     CLOSE #15
6450     DELETE eraseDevice$ & "_data_" & eraseName$
6460   END IF
6470 END DEFine eraseProject
6480 :
6490 :
6500 REMark =========================================================
6510 REMark Basic headings and messages
6520 REMark =========================================================
6530 DEFine PROCedure showMessage(message$)
6540   PAPER #fieldWidth9,7
6550   CLS   #fieldWidth9
6560   PAPER #fieldWidth9,fieldWidth4
6570   INK   #fieldWidth9,2
6580   AT    #fieldWidth9,0,(55 - LEN(message$)) DIV 2
6590   PRINT #fieldWidth9,message$;
6600 END DEFine showMessage
6610 :
6620 :
6630 DEFine PROCedure drawHeading(mode,printerFlag)
6640   LOCal i,headerChannel,scaleChannel
6650   :
6660   IF printerFlag THEN
6670     headerChannel = 14
6680     scaleChannel  = 14
6690   ELSE
6700     headerChannel = 7
6710     scaleChannel  = 11
6720     CLS #7
6730   END IF
6740   :
6750   SELect ON mode
6760     =1
6770       PRINT #headerChannel,"Dur'n Prerequisites                    Cost"
6780     =2
6790       PRINT #headerChannel,"Scale=";chartScale
6800       FOR i = 0 TO 40 STEP fieldWidth10
6810         positionAt scaleChannel,0,i,20
6820         PRINT #scaleChannel,chartLeftOffset + i * chartScale;
6830       END FOR i
6840       PRINT #scaleChannel
6850   END SELect
6860 END DEFine drawHeading
6870 :
6880 :
6890 DEFine PROCedure drawVerticalSplit(y1,height)
6900   LOCal topY,bottomY
6910   topY    = 1120 - 80 * y1
6920   bottomY = topY + 80 * height + fieldWidth10
6930   LINE #fieldWidth3,922,topY TO 922,bottomY,930,topY TO 930,bottomY
6940 END DEFine drawVerticalSplit
6950 :
6960 :
6970 DEFine PROCedure drawGrid(y1,height)
6980   LOCal startY,endY,i,gridX
6990   startY = 1120 - 80 * y1
7000   endY   = startY + height * 80 + fieldWidth10
7010   :
7020   SELect ON displayMode
7030     =2
7040       IF chartLeftOffset = 0 THEN
7050         gridX = 178
7060       ELSE
7070         gridX = (5 - (chartLeftOffset DIV chartScale) MOD 5) * 35.6
7080         IF chartLeftOffset MOD (chartScale * 5) = 0 THEN
7090           gridX = 0
7100         END IF
7110       END IF
7120       :
7130       INK #10,fieldWidth4
7140       FOR i = gridX TO 1700 STEP 178
7150         LINE #10,i,startY TO i,endY
7160       END FOR i
7170   END SELect
7180   INK #10,0
7190 END DEFine drawGrid
7200 :
7210 :
7220 REMark =========================================================
7230 REMark Navigation in activity list
7240 REMark =========================================================
7250 DEFine PROCedure moveUp
7260   IF currentActivityIndex = -1 OR NOT projectListActive THEN RETurn
7270   IF currentActivity = listPositionToActivity%(0) THEN RETurn
7280   :
7290   currentActivity = listPositionToActivity%(activityToListPosition%(currentActivity) - 1)
7300   clearPointerSquare
7310   :
7320   IF currentLineInView = 0 THEN
7330     topActivity = listPositionToActivity%(activityToListPosition%(topActivity) - 1)
7340     SCROLL #fieldWidth3,fieldWidth10
7350     listActivities topActivity,0,1,displayMode,0
7360   ELSE
7370     currentLineInView = currentLineInView - 1
7380   END IF
7390   :
7400   clearPointerSquare
7410 END DEFine moveUp
7420 :
7430 :
7440 DEFine PROCedure moveDown
7450   IF currentActivityIndex = -1 OR NOT projectListActive THEN RETurn
7460   IF currentActivity = listPositionToActivity%(currentActivityIndex) THEN RETurn
7470   :
7480   currentActivity = listPositionToActivity%(activityToListPosition%(currentActivity) + 1)
7490   clearPointerSquare
7500   :
7510   IF currentLineInView = 14 THEN
7520     topActivity = listPositionToActivity%(activityToListPosition%(topActivity) + 1)
7530     SCROLL #fieldWidth3,-fieldWidth10
7540     listActivities currentActivity,14,1,displayMode,0
7550   ELSE
7560     currentLineInView = currentLineInView + 1
7570   END IF
7580   :
7590   clearPointerSquare
7600 END DEFine moveDown
7610 :
7620 :
7630 DEFine PROCedure clearPointerSquare
7640   AT #4,currentLineInView,2
7650   PRINT #4," ";
7660 END DEFine clearPointerSquare
7670 :
7680 :
7690 REMark =========================================================
7700 REMark Utility functions
7710 REMark =========================================================
7720 DEFine PROCedure trimTrailingSpaces(text$)
7730   IF text$ = FILL$(" ",LEN(text$)) THEN
7740     text$ = ""
7750     RETurn
7760   END IF
7770   :
7780   REPeat trimLoop
7790     IF text$(LEN(text$)) = " " THEN
7800       text$ = text$(1 TO LEN(text$) - 1)
7810     ELSE
7820       EXIT trimLoop
7830     END IF
7840   END REPeat trimLoop
7850 END DEFine trimTrailingSpaces
7860 :
7870 :
7880 DEFine FuNction min(x,y)
7890   IF x < 0 OR y < 0 THEN
7900     RETurn 0
7910   ELSE IF x < y THEN
7920     RETurn x
7930   ELSE
7940     RETurn y
7950   END IF
7960 END DEFine min
7970 :
7980 :
7990 DEFine FuNction dt$(shortDate$)
8000   LOCal fullYear$
8010   IF shortDate$(1 TO 2) < 61 THEN
8020     fullYear$ = "20" & shortDate$(1 TO 2)
8030   ELSE
8040     fullYear$ = "19" & shortDate$(1 TO 2)
8050   END IF
8060   RETurn fullYear$
8070 END DEFine dt$
8080 :
8090 :
8100 DEFine PROCedure setMonthOffsets(year$)
8110   LOCal i
8120   IF year$ MOD fieldWidth4 = 0 THEN
8130     RESTORE 8160
8140   ELSE
8150     RESTORE 8150
8160   END IF
8170   :
8180   FOR i = 0 TO 13
8190     READ monthOffset%(i)
8200   END FOR i
8210 END DEFine setMonthOffsets
8220 :
8230 DATA 335,1,32,60,91,121,152,182,213,244,274,305,335,366
8240 DATA 336,1,32,61,92,122,153,183,214,245,275,306,336,367
8250 :
8260 :
8270 DEFine PROCedure showError(errorNo,detail$)
8280   AT    #0,0,0
8290   PAPER #fieldWidth9,2
8300   CLS   #fieldWidth9
8310   INK   #fieldWidth9,7
8320   :
8330   SELect ON errorNo
8340     =1,5
8350       errorText$ = " error in prereqs"
8360     =2
8370       errorText$ = " no job " & detail$
8380     =fieldWidth3,fieldWidth4
8390       errorText$ = " prereq. " & detail$ & "; loop error"
8400     =6
8410       errorText$ = " too many prereqs in job " & (edgeChild%(currentEdgePointer) + 1)
8420     =7
8430       errorText$ = " no of prereqs >10"
8440     =8,15,16
8450       errorText$ = " no more allowed"
8460     =fieldWidth9
8470       errorText$ = " no activity"
8480     =fieldWidth10
8490       errorText$ = " invalid date"
8500     =11
8510       errorText$ = " device error"
8520     =13
8530       errorText$ = " 1961<year<2025"
8540     =14
8550       errorText$ = " no holiday"
8560     =17
8570       errorText$ = " no milestone"
8580     =18
8590       errorText$ = " disabled; List to enable"
8600     =19
8610       errorText$ = " total length of project > 65534 "
8620   END SELect
8630   :
8640   errorText$ = errorText$ & "; press any key"
8650   PRINT #fieldWidth9,errorText$;
8660   lastKey = CODE(INKEY$(#4,-1))
8670 END DEFine showError