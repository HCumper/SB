100 REMark =========================================================
110 REMark QL PROJECT PLANNER - READABLE REWRITE
120 REMark Based on original by H. Beyzaii
130 REMark This version focuses on readability and maintainability.
140 REMark =========================================================

150 :
160 REMark ---------------------------
170 REMark Configuration
180 REMark ---------------------------
190 programDevice$ = "flp1"
200 dataDevice$    = "flp1"
210 printerPort$   = "par"
220 :
230 REMark ---------------------------
240 REMark Main program entry
250 REMark ---------------------------
260 IF PEEK(163890) THEN
270   MODE 4
280   shadowColour = 0
290 ELSE
300   shadowColour = 224
310 END IF
320 :
330 MODE 4
340 WINDOW 480,255,20,0
350 PAPER 0
360 CLS
370 :
380 CSIZE 0,0
390 AT 3,8
400 CSIZE 3,1
410 INK 2
420 PRINT "QL.PROJECT PLANNER ";
430 :
440 CSIZE 0,0
450 AT 4,58
460 PRINT "version 1.1"
470 :
480 CSIZE 0,0
490 AT 6,9
500 CSIZE 1,0
510 PRINT "1985 Triptych Publishing"
520 :
530 CSIZE 0,0
540 AT 19,10
550 PRINT "by H. Beyzaii"
560 :
570 INK #0,7
580 OVER #0,-1
590 :
600 customCharBase = RESPR(1024)
610 LBYTES programDevice$ & "_PP_udg", customCharBase
620 :
630 OPEN #10, con__1
640 CHAR_USE #10,0,customCharBase
650 :
660 OPEN #3,  con__1
670 OPEN #4,  con__1
680 OPEN #8,  con__1
690 OPEN #5,  scr_
700 OPEN #6,  scr_
710 OPEN #7,  scr_
720 OPEN #9,  scr_
730 OPEN #11, scr_
740 :
750 IF PEEK_L(163872) = 262144 THEN
760   maxActivities = 59
770 ELSE
780   maxActivities = 98
790 END IF
800 :
810 maxSpecialHolidays = 80
820 fieldWidth3  = 3
830 fieldWidth4  = 4
840 fieldWidth9  = 9
850 fieldWidth10 = 10
860 :
870 DIM successorHead%(maxActivities)
880 DIM listPositionToActivity%(maxActivities)
890 DIM activityToListPosition%(maxActivities)
900 DIM edgeChild%((maxActivities + 1) * fieldWidth10)
910 DIM edgeNext%((maxActivities + 1) * fieldWidth10)
920 :
930 DIM activityName$(maxActivities,16)
940 DIM activityDuration$(maxActivities,fieldWidth3)
950 DIM activityPrereqText$(maxActivities,30)
960 DIM activityCost$(maxActivities,6)
970 :
980 DIM specialHolidayDate$(maxSpecialHolidays,6)
990 DIM workingDayEnabled%(6)
1000 DIM monthName$(11,fieldWidth3)
1010 DIM milestoneDate$(fieldWidth10,6)
1020 DIM milestoneActivity%(fieldWidth10)
1030 DIM calendarColumnX%(2)
1040 DIM monthRowY%(11)
1050 DIM monthOffset%(13)
1060 :
1070 REMark Computed schedule arrays in reserved memory
1080 earliestStartAddr = customCharBase + 60
1090 latestFinishAddr  = earliestStartAddr + (maxActivities + 1) * 2
1100 freeFloatAddr     = latestFinishAddr  + (maxActivities + 1) * 2
1110 interferenceAddr  = freeFloatAddr     + (maxActivities + 1) * 2
1120 holidayWorkAddr   = interferenceAddr  + (maxActivities + 1) * 2
1130 holidayDayAddr    = holidayWorkAddr
1140 :
1150 DIM printerGraphic$(fieldWidth3,5)
1160 :
1170 loadProgramData
1180 initializeProject
1190 initializeViewState
1200 :
1210 currentMenuX = 0
1220 currentMenuY = 0
1230 :
1240 setupWindowSet 1
1250 drawHeading 1,0
1260 drawVerticalSplit 14,15
1270 createNewProjectDisplay
1280 :
1290 REPeat mainLoop
1300   CLS #8
1310   PAPER #fieldWidth9,7
1320   CLS #fieldWidth9
1330   :
1340   IF milestoneListMode THEN
1350     showMessage " to change milestones select Modify or Delete "
1360   END IF
1370   :
1380   handleMenuHighlight currentMenuX,currentMenuY,6,lastKey,1
1390   menuCode = currentMenuY * 100 + currentMenuX
1400   :
1410   SELect ON menuCode
1420     =0
1430       addActivity
1440     =9
1450       insertActivity
1460     =18
1470       modifyActivity
1480     =27
1490       moveActivity
1500     =36
1510       deleteActivity
1520     =45
1530       gotoActivity
1540     =100
1550       showList 0
1560     =109
1570       showChart 0
1580     =118
1590       setupWindowSet 2
1600       specificationMenu
1610       IF milestoneListMode THEN
1620         currentMenuY = 0
1630         drawMenu 1,currentMenuX,currentMenuY
1640       ELSE
1650         drawMenu 1,currentMenuX,currentMenuY
1660       END IF
1670     =127
1680       setupWindowSet 2
1690       fileMenu
1700       setupWindowSet 1
1710       drawHeading 1,0
1720       drawVerticalSplit 14,15
1730       drawMenu 1,currentMenuX,currentMenuY
1740     =136
1750       reportsMenu
1760       drawMenu 1,currentMenuX,currentMenuY
1770     =145
1780       printerMenu
1790       drawMenu 1,currentMenuX,currentMenuY
1800   END SELect
1810 END REPeat mainLoop
1820 :
1830 :
1840 REMark =========================================================
1850 REMark Program data loading
1860 REMark =========================================================
1870 DEFine PROCedure loadProgramData
1880   LOCal i,j,charCode
1890   :
1900   dataFileHandle = FOPEN(#15, programDevice$ & "_PP_progdata")
1910   :
1920   FOR i = 0 TO fieldWidth3
1930     printerGraphic$(i) = ""
1940     FOR j = 1 TO 5
1950       INPUT #15, charCode
1960       printerGraphic$(i) = printerGraphic$(i) & CHR$(charCode)
1970     END FOR j
1980   END FOR i
1990   :
2000   projectName$ = FILL$(" ",20)
2010   storageBias  = 32767
2020   escapeMode   = 0
2030   :
2040   FOR i = 0 TO 11
2050     INPUT #15, monthName$(i)
2060   END FOR i
2070   :
2080   CLOSE #15
2090 END DEFine loadProgramData
2100 :
2110 :
