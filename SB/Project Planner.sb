2910 DEFine PROCedure createWindow(channel,width,height,x,y,paperColour,hasBorder,borderWidth,borderInk)
2920   WINDOW #channel,width,height,x,y
2930   PAPER  #channel,paperColour
2940   CLS    #channel
2950   IF hasBorder THEN
2960     BORDER #channel,borderWidth,borderInk
2970   END IF
2980 END DEFine createWindow
