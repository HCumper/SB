3010 REMark =========================================================
3020 REMark Menu display and movement
3030 REMark =========================================================
3040 DEFine PROCedure drawMenu(menuMode,x,y)
3050   OVER #5,0
3060   INK  #5,0
3070   CLS  #5
3080   :
3090   SELect ON menuMode
3100     =1
3110       menuText$ = " Add     Insert   Modify    Move    Delete    Goto  List    Chart    Spec      File    Report    Print"
3120     =2
3130       menuText$ = " Dir     Save     Load     Erase    Menu"
3140     =fieldWidth3
3150       menuText$ = "Units    Dates    T/Cost   Hols     MStone   Menu"
3160     =fieldWidth4
3170       menuText$ = " Name    Remark   Start    W/days   Hol-MS   Menu"
3180     =5
3190       menuText$ = " Spec     List    Chart    Units    Dates    Menu"
3200   END SELect
3210   :
3220   PRINT #5,menuText$;
3230   OVER #5,-1
3240   INK  #5,5
3250   drawMenuBar x,y
3260 END DEFine drawMenu
3270 :
3280 :
3290 DEFine PROCedure handleMenuHighlight(x,y,itemCount,keyCode,allowVertical)
3300   REPeat keyLoop
3310     keyCode = CODE(INKEY$(#fieldWidth3,-1))
3320     :
3330     SELect ON keyCode
3340       =32,200
3350         drawMenuBar x,y
3360         x = (x + fieldWidth9) MOD (itemCount * fieldWidth9)
3370         drawMenuBar x,y
3380       =192
3390         drawMenuBar x,y
3400         x = (x - fieldWidth9) MOD (itemCount * fieldWidth9)
3410         drawMenuBar x,y
3420       =208
3430         IF allowVertical THEN
3440           drawMenuBar x,y
3450           y = (y - 1) MOD 2
3460           drawMenuBar x,y
3470         END IF
3480       =216
3490         IF allowVertical THEN
3500           drawMenuBar x,y
3510           y = (y + 1) MOD 2
3520           drawMenuBar x,y
3530         END IF
3540       =196
3550         IF currentActivityIndex > -1 AND chartModeEnabled AND chartLeftOffset >= 25 * chartScale THEN
3560           chartLeftOffset = chartLeftOffset - 25 * chartScale
3570           drawHeading 2,0
3580           PAN #10,150
3590           drawGrid 14,15
3600           listActivities topActivity,0,min(14,currentActivityIndex - activityToListPosition%(topActivity)) + 1,2,0
3610         END IF
3620       =204
3630         IF currentActivityIndex > -1 AND chartModeEnabled AND chartLeftOffset + 48 * chartScale <= totalProjectLength THEN
3640           chartLeftOffset = chartLeftOffset + 25 * chartScale
3650           drawHeading 2,0
3660           PAN #10,-150
3670           drawGrid 14,15
3680           listActivities topActivity,0,min(14,currentActivityIndex - activityToListPosition%(topActivity)) + 1,2,0
3690         END IF
3700       =212
3710         moveUp
3720       =220
3730         moveDown
3740     END SELect
3750     :
3760     IF keyCode = fieldWidth10 THEN EXIT keyLoop
3770   END REPeat keyLoop
3780 END DEFine handleMenuHighlight
3790 :
3800 :
3810 DEFine PROCedure drawMenuBar(x,y)
3820   AT    #5,y,x
3830   BLOCK #5,52,fieldWidth10,x*8,y*fieldWidth10,2
3840 END DEFine drawMenuBar
3850 :
