2150 DEFine PROCedure setupWindowSet(layoutNo)
2160   SELect ON layoutNo
2170     =1
2180       createWindow fieldWidth3,512,256,0,0,fieldWidth4,0
2190       createWindow fieldWidth3,456,152,38,47,shadowColour,0
2200       createWindow #6,456,22,38,16,shadowColour,0
2210       createWindow #6,160,22,28,fieldWidth10,7,1,1,0
2220       createWindow #7,300,22,186,fieldWidth10,7,1,1,0
2230       createWindow fieldWidth3,456,152,28,41,7,1,1,0
2240       createWindow #8,456,24,38,208,shadowColour,0
2250       createWindow #8,456,24,28,202,7,1,1,0
2260       :
2270       WINDOW #8,451,10,32,203
2280       WINDOW #fieldWidth9,451,fieldWidth10,32,213
2290       WINDOW #fieldWidth3,451,150,32,42
2300       WINDOW #6,154,20,32,11
2310       WINDOW #7,294,20,190,11
2320       WINDOW #4,152,150,32,42
2330       WINDOW #10,290,150,192,42
2340       WINDOW #11,294,fieldWidth10,190,21
2350       :
2360       createWindow #5,414,22,61,231,shadowColour,0
2370       createWindow #5,416,22,48,223,7,1,1,0
2380       :
2390       CSIZE #fieldWidth3,1,0
2400       CSIZE #4,1,0
2410       CSIZE #5,1,0
2420       CSIZE #6,0,0
2430       CSIZE #8,1,0
2440       CSIZE #fieldWidth9,1,0
2450       AT    #10,0,0
2460       CSIZE #10,0,0
2470       CSIZE #11,0,0
2480       SCALE #10,1200,0,0
2490       SCALE #fieldWidth3,1200,0,0
2500       :
2510       INK #fieldWidth3,0
2520       INK #4,5
2530       INK #5,0
2540       INK #6,0
2550       INK #7,0
2560       INK #8,0
2570       INK #10,0
2580       INK #11,0
2590       :
2600       OVER  #4,-1
2610       PAPER #4,7
2620       PAPER #10,7
2630       PAPER #11,7
2640       :
2650       menuPrompt$ = "No  Activity"
2660       PRINT #6, menuPrompt$
2670     =2
2680       CSIZE #fieldWidth3,1,0
2690       CSIZE #4,2,0
2700       CSIZE #5,1,0
2710       CSIZE #8,1,0
2720       CSIZE #fieldWidth9,1,0
2730       :
2740       INK #fieldWidth3,7
2750       INK #8,0
2760       :
2770       createWindow fieldWidth3,512,256,0,0,2,0
2780       createWindow fieldWidth3,456,180,32,16,2,1,2,7
2790       WINDOW #4,448,176,36,18
2800       PAPER #4,2
2810       createWindow #8,456,24,32,202,7,1,1,0
2820       createWindow #5,416,22,52,223,7,1,1,0
2830       PAPER #fieldWidth3,0
2840       :
2850       WINDOW #8,451,fieldWidth10,36,203
2860       WINDOW #fieldWidth9,451,fieldWidth10,36,213
2870   END SELect
2880 END DEFine setupWindowSet
2890 :
